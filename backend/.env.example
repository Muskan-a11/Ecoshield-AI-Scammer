# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/echoshield

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE_MINUTES=1440

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# Deepfake model (optional path to trained weights)
DEEPFAKE_MODEL_PATH=

# Deepfake detection threshold (0.0 - 1.0)
DEEPFAKE_THRESHOLD=0.6

# Anthropic API key for AI Negotiator (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
